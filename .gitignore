# =============================================================================
# claude-code-dock — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Arquivos de ambiente — NUNCA commitar
# Contém caminhos locais e configurações específicas do host
# -----------------------------------------------------------------------------
.env
.env.*

# -----------------------------------------------------------------------------
# Configurações do Claude Code — NUNCA commitar
# Contém credenciais de autenticação, tokens e dados sensíveis
# configs/<session>/ (CONFIG_BASE_PATH/REMOTE_SESSION_NAME) é montado como
# volume e contém ~/.claude/ do container. config/ é o layout legado
# (pre-multi-sessão) — mantido aqui para quem ainda usa o CONFIG_PATH antigo.
# -----------------------------------------------------------------------------
configs/*
!configs/.gitkeep
config/*
!config/.gitkeep

# -----------------------------------------------------------------------------
# Workspaces locais
# Projetos do usuário não devem fazer parte deste repositório
# -----------------------------------------------------------------------------
workspaces/*
!workspaces/.gitkeep

# -----------------------------------------------------------------------------
# Ferramentas de desenvolvimento local — não fazem parte do projeto
# -----------------------------------------------------------------------------
.omc/

# -----------------------------------------------------------------------------
# Backups gerados pelos scripts
# -----------------------------------------------------------------------------
backups/
*.tar.gz
*.tar.bz2
*.zip

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Artefatos Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Gerado automaticamente por install.sh/update.sh/session-up.sh quando
# CLAUDE_SOURCE_PATH está setado (ver docker-compose.yml) — nunca commitar,
# o conteúdo é derivado do .env local, não configuração do projeto.
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Sistemas operacionais
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Editores e IDEs
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs
*~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Node.js (caso o projeto adicione scripts Node no futuro)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

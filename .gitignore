# =============================================================================
# claude-code-dock — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Arquivos de ambiente — NUNCA commitar
# Contém caminhos locais e configurações específicas do host
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Configurações do Claude Code — NUNCA commitar
# Contém credenciais de autenticação, tokens e dados sensíveis
# O diretório config/ é montado como volume e contém ~/.claude/ do container
# -----------------------------------------------------------------------------
config/*
!config/.gitkeep

# -----------------------------------------------------------------------------
# Workspaces locais
# Projetos do usuário não devem fazer parte deste repositório
# -----------------------------------------------------------------------------
workspaces/*
!workspaces/.gitkeep

# -----------------------------------------------------------------------------
# Ferramentas de desenvolvimento local — não fazem parte do projeto
# -----------------------------------------------------------------------------
.omc/

# -----------------------------------------------------------------------------
# Backups gerados pelos scripts
# -----------------------------------------------------------------------------
backups/
*.tar.gz
*.tar.bz2
*.zip

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Artefatos Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Sistemas operacionais
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Editores e IDEs
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs
*~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Node.js (caso o projeto adicione scripts Node no futuro)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

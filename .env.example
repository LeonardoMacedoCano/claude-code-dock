# Copy this file: cp .env.example .env
# Edit .env with your values. Never commit .env (already in .gitignore).

# Path to the ClaudeCodeDock project on the host (where the Dockerfile is)
# Examples:
#   Standard Linux:  CLAUDE_SOURCE_PATH=/home/user/claude-code-dock
#   Unraid appdata:  CLAUDE_SOURCE_PATH=/mnt/user/appdata/claude-code-dock
#   Local test:      CLAUDE_SOURCE_PATH=.
CLAUDE_SOURCE_PATH=/mnt/user/appdata/claude-code-dock

# Path to your projects on the host (mounted at /workspace inside the container)
# Examples:
#   Standard Linux:  WORKSPACE_PATH=/home/user/projects
#   Unraid array:    WORKSPACE_PATH=/mnt/user/projects
#   Unraid cache:    WORKSPACE_PATH=/mnt/cache/projects
#   Synology:        WORKSPACE_PATH=/volume1/projects
#   Local test:      WORKSPACE_PATH=./workspaces
WORKSPACE_PATH=/mnt/user/projects

# Path where Claude Code credentials are stored (mounted at /home/node/.claude)
# Keep this directory secure — do not share or commit it.
# Examples:
#   Unraid (recommended): CONFIG_PATH=/mnt/user/appdata/claude-code-dock/config
#   Standard Linux:       CONFIG_PATH=/home/user/claude-code-dock/config
#   Local test:           CONFIG_PATH=./config
CONFIG_PATH=/mnt/user/appdata/claude-code-dock/config

# Container execution mode (determines PID 1 process)
#   interactive  — runs claude inside a tmux session (default, connect via attach.sh)
#   remote       — runs claude --remote-control inside a tmux session
#   shell        — runs bash (useful for debugging)
AUTO_START_MODE=interactive

# Auto-approve mode
#   true  — Claude runs without confirmation prompts (--dangerously-skip-permissions)
#   false — Claude asks for approval before each action
# Only applies to interactive mode.
CLAUDE_AUTO_APPROVE=true

# Remote Control session name (only used when AUTO_START_MODE=remote)
# Leave empty to use the auto-generated hostname.
# Example: REMOTE_SESSION_NAME=HomeServer
REMOTE_SESSION_NAME=

# Extra arguments appended to the final Claude command
# Examples: --model sonnet | --verbose | --debug
CLAUDE_EXTRA_ARGS=

# Container timezone
TZ=America/Sao_Paulo

# Git identity for commits made inside the container (optional)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

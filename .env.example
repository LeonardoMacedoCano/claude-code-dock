# Copy this file: cp .env.example .env
# Edit .env with your values. Never commit .env (already in .gitignore).
#
# Structure: REQUIRED first (you must set these), then OPTIONAL, grouped by
# topic (skip any group that doesn't apply to you). Full reference and
# usage-profile guide: CLAUDE.md#usage-profiles.

# =============================================================================
# REQUIRED
# =============================================================================

# Path to your projects on the host (mounted at /workspace inside the container)
# Examples:
#   Standard Linux:  WORKSPACE_PATH=/home/user/projects
#   Unraid array:    WORKSPACE_PATH=/mnt/user/projects
#   Unraid cache:    WORKSPACE_PATH=/mnt/cache/projects
#   Synology:        WORKSPACE_PATH=/volume1/projects
#   Local test:      WORKSPACE_PATH=./workspaces
WORKSPACE_PATH=/mnt/user/projects

# Base directory where per-session config subdirectories are created.
# Each session gets its own isolated directory: CONFIG_BASE_PATH/REMOTE_SESSION_NAME
# Keep this directory secure — do not share or commit it.
# Examples:
#   Unraid (recommended): CONFIG_BASE_PATH=/mnt/user/appdata/claude-code-dock/configs
#   Standard Linux:       CONFIG_BASE_PATH=/home/user/claude-code-dock/configs
#   Local test:           CONFIG_BASE_PATH=./configs
CONFIG_BASE_PATH=/mnt/user/appdata/claude-code-dock/configs

# Unique identifier for this session.
# Used as: config subdirectory name, backup filename prefix, and default CONTAINER_NAME suffix.
# Two containers with the same REMOTE_SESSION_NAME cannot run simultaneously on the same host.
# Examples: homepage, finances, my-project, server1
REMOTE_SESSION_NAME=

# =============================================================================
# OPTIONAL — Container & execution mode
# =============================================================================
# Everything in this group has a working default. Set only what you want to
# change from "Claude in an interactive terminal, no auto-approve".

# Docker container name. Leave unset ONLY if this is the single/only
# claude-code-dock instance on this host: the unset default is the plain
# literal "claude-code-dock", NOT derived from REMOTE_SESSION_NAME. Running
# more than one instance manually (one project folder per session, each with
# its own docker-compose.yml + .env copy) without setting this in every
# folder means they will collide on the same container name. install.sh and
# new-session.sh both set this for you automatically — this note only
# matters if you're managing .env by hand.
CONTAINER_NAME=

# Execution mode (determines PID 1 process):
#   interactive  — runs claude inside a tmux session (default, connect via attach.sh)
#   remote       — runs claude --remote-control inside a tmux session (Claude Remote Control)
#   shell        — runs bash (useful for debugging)
AUTO_START_MODE=interactive

# true  — Claude runs without confirmation prompts (--dangerously-skip-permissions)
# false — Claude asks for approval before each action (recommended default)
# Only set true once you trust the workspace this container points at.
# Combined with GITHUB_TOKEN_FILE below and restart:unless-stopped, this runs
# an unattended agent that can push with no human checkpoint on each command
# -- see docs/security.md#credential-protection (point 6) before setting
# both true and a token on the same session.
CLAUDE_AUTO_APPROVE=false

# Extra arguments appended to the final Claude command (quote-aware parsing).
# Examples: --model sonnet | --verbose | --append-system-prompt "be terse"
CLAUDE_EXTRA_ARGS=

# Claude Code npm package version to install (default: latest).
# Pin a specific version to avoid unexpected updates on rebuild.
CLAUDE_CODE_VERSION=latest

# Container timezone
TZ=America/Sao_Paulo

# =============================================================================
# OPTIONAL — User & permissions
# =============================================================================
# Skip this group unless the host user that owns WORKSPACE_PATH/CONFIG_BASE_PATH
# isn't UID/GID 1000 (run `id -u` / `id -g` on the host to check).

# UID/GID the container remaps its built-in 'node' user to before dropping
# root. Avoids having to `chown -R 1000:1000` your host directories.
# PUID/PGID=0 is rejected (refuses to run as root).
PUID=1000
PGID=1000

# =============================================================================
# OPTIONAL — GitHub / Git integration
# =============================================================================
# Skip this whole group if you don't need Claude to commit or push from
# inside the container (e.g. you commit from your own machine instead).

# Git identity for commits made inside the container.
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

# HOST path to a file containing your GitHub Personal Access Token — required
# for git push / pulling private repos. docker-compose.yml mounts this file
# automatically, read-only, into the container. The token's value never sits
# in .env or in the container's process environment, only this path does —
# see docs/security.md for the full threat model.
# Prefer a fine-grained PAT scoped to the single repo you need (Settings ->
# Developer settings -> Fine-grained tokens), not a classic token with the
# full "repo" scope across your whole account -- especially if
# CLAUDE_AUTO_APPROVE=true above, since a leaked token is only as bounded as
# its own scope (see docs/security.md#credential-protection, point 6).
#   echo -n github_pat_xxx > /srv/claude-secrets/github_token && chmod 600 ...
GITHUB_TOKEN_FILE=

# HTTPS URL of a repo to auto-clone into /workspace on first start, if it's
# empty. SSH is not supported. Requires GITHUB_TOKEN_FILE if private.
GIT_REPO_URL=

# =============================================================================
# OPTIONAL — Shared configuration across sessions
# =============================================================================
# Skip unless you're running multiple sessions and want one global
# CLAUDE.md / commands/ folder applied to all of them automatically.

# Files placed here are applied at startup to every session:
#   CLAUDE.md      → global instructions (coding style, commit rules, preferences)
#   commands/      → global slash commands / skills (*.md files)
# Instance-specific instructions go in: CONFIG_BASE_PATH/<session>/CLAUDE-local.md
SHARED_CONFIG_PATH=

# =============================================================================
# OPTIONAL — Build source (advanced / contributors only)
# =============================================================================
# Skip this whole group unless you're pinning a specific published tag or
# building claude-code-dock itself from a local clone. Priority when several
# are set: CLAUDE_SOURCE_PATH > CLAUDE_DOCK_TAG > CLAUDE_DOCK_VERSION.
# install.sh/update.sh print "BUILD SOURCE: ..." so you can confirm which one
# was actually used; the running container reports it too (`./scripts/status.sh`).

# Published image tag to pull (default: latest). `:latest` moves on every
# push to main and a weekly rebuild (new @anthropic-ai/claude-code releases,
# no staging step). `:stable` only moves when a maintainer manually promotes
# a build — prefer it if you don't want to ride the weekly bump.
# Examples: CLAUDE_DOCK_TAG=stable | CLAUDE_DOCK_TAG=v1.0.0
CLAUDE_DOCK_TAG=latest

# Path to a local claude-code-dock clone to build from instead of pulling
# (only needed for local development/testing of claude-code-dock itself).
# When set, this ALWAYS wins over CLAUDE_DOCK_TAG/CLAUDE_DOCK_VERSION.
# install.sh/update.sh/session-up.sh generate (or remove) a
# docker-compose.override.yml next to this file to match — it forces every
# `docker compose` invocation from this directory to always build fresh from
# this path into its own tag, never silently reusing a previously
# pulled/built image, regardless of which tool runs `up` (this project's own
# scripts, a bare `docker compose up -d`, or a third-party tool like
# Unraid's Compose Manager plugin — as long as it also runs from this same
# directory; see docs/docker.md#local-development for the details and the
# one exception, tools that copy the compose file elsewhere before running it).
# Examples: CLAUDE_SOURCE_PATH=. | CLAUDE_SOURCE_PATH=/home/user/claude-code-dock
CLAUDE_SOURCE_PATH=

# claude-code-dock git ref to build from when the pull fails and
# CLAUDE_SOURCE_PATH is unset (default: main). Rarely needs changing.
CLAUDE_DOCK_VERSION=main

# =============================================================================
# OPTIONAL — Backups
# =============================================================================
# `scripts/backup.sh` never schedules itself -- it only runs when invoked
# manually or by whatever calls it. For a daily automatic backup, run:
#   ./scripts/install.sh --with-backup-cron
# This adds a host crontab entry (idempotent), and automatically includes
# --encrypt in that cron line if BACKUP_ENCRYPT_PASSPHRASE below is already
# set at the time it runs.

# Number of backups to keep per session (oldest are removed automatically)
BACKUP_RETENTION=10

# Passphrase for `scripts/backup.sh --encrypt` (non-interactive GPG, e.g. from
# cron). Without it, --encrypt still works but gpg prompts interactively.
# Storing a passphrase here makes .env as sensitive as the backups it
# protects — keep it chmod 600.
BACKUP_ENCRYPT_PASSPHRASE=

# =============================================================================
# OPTIONAL — Watchdog
# =============================================================================
# restart:unless-stopped only reacts to the container actually exiting -- it
# never restarts one Docker still reports as running but "unhealthy" (e.g. a
# wedged tmux pane). Two ways to close that gap, pick one:
#   1. `./scripts/install.sh --with-watchdog` -- adds a host crontab entry
#      (recommended; no extra container, no docker.sock exposure)
#   2. `docker compose -f docker-compose.yml -f docker-compose.watchdog.yml up -d`
#      -- a sidecar container instead of cron, at the cost of mounting
#      /var/run/docker.sock (root-equivalent host access) into it; see that
#      file's header comment before using it.
# WATCHDOG_NTFY_URL is read by scripts/watchdog.sh either way — on the host
# for option 1, or passed into the sidecar's environment for option 2.

# Webhook URL notified when the watchdog restarts the container, fails to
# restart it, or skips it due to a fatal misconfiguration marker. Works with
# an ntfy.sh topic or any webhook accepting a raw POST body.
# Example: WATCHDOG_NTFY_URL=https://ntfy.sh/my-claude-dock-alerts
WATCHDOG_NTFY_URL=

# Seconds between checks. Only read by the docker-compose.watchdog.yml
# sidecar (option 2 above) -- the crontab entry from option 1 is scheduled by
# cron itself (every 5 minutes), not by this variable.
WATCHDOG_INTERVAL=300

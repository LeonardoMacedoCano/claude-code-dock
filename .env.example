# Copy this file: cp .env.example .env
# Edit .env with your values. Never commit .env (already in .gitignore).

# --- Which claude-code-dock build claude-code-dock itself runs from ---
# Priority, highest first: CLAUDE_SOURCE_PATH > CLAUDE_DOCK_IMAGE > CLAUDE_DOCK_VERSION.
# install.sh/update.sh always print "BUILD SOURCE: ..." so you can see which
# one was actually used, and the running container reports it too (startup
# log's "Build source:" line, or `./scripts/status.sh`).

# Prebuilt image to pull (optional — default: ghcr.io/leonardomacedocano/claude-code-dock:latest)
# `docker compose pull` / install.sh / update.sh fetch this by default — no
# local apt-get/npm build needed. Only override if you publish your own fork's
# image to a different registry/tag. Ignored entirely when CLAUDE_SOURCE_PATH
# is set below.
#
# `:latest` moves on every push to main and on a weekly cron rebuild (to pick
# up new @anthropic-ai/claude-code releases) -- with no staging step, so it
# can in principle pick up a CLI release that breaks something. `:stable`
# only moves when a maintainer manually promotes a specific build (see
# CLAUDE.md's scripts/update.sh section). Prefer it if you'd rather not ride
# the weekly bump automatically:
#   CLAUDE_DOCK_IMAGE=ghcr.io/leonardomacedocano/claude-code-dock:stable
CLAUDE_DOCK_IMAGE=

# claude-code-dock git ref to build from when NOT pulling the prebuilt image
# and NOT using CLAUDE_SOURCE_PATH below (optional — default: main). Used when
# the pull fails, or you explicitly run `docker compose build` with
# CLAUDE_SOURCE_PATH unset.
# Set to a released tag once available to pin a version, e.g. CLAUDE_DOCK_VERSION=v1.0.0
CLAUDE_DOCK_VERSION=main

# Path to a local claude-code-dock clone to build from instead of pulling the
# prebuilt image or building from GitHub (optional, advanced). Only needed for
# local development/testing of claude-code-dock itself.
#
# When set, this ALWAYS wins — install.sh/update.sh switch to
# `docker compose build --no-cache`, so your local folder is guaranteed to be
# what's built, never a stale pulled/cached image and never GitHub. If you run
# `docker compose` commands manually instead of the scripts, you must force
# the same guarantee yourself: a bare `docker compose up -d` will NOT rebuild
# if an image is already tagged locally (e.g. from a prior pull) — use
# `docker compose build --no-cache && docker compose up -d`, or the one-liner
# `docker compose up -d --build`. See docs/docker.md#local-development.
# Examples:
#   Local test:      CLAUDE_SOURCE_PATH=.
#   Local clone:      CLAUDE_SOURCE_PATH=/home/user/claude-code-dock
CLAUDE_SOURCE_PATH=

# UID/GID the container runs Claude Code as (optional -- default: 1000/1000,
# the built-in 'node' user baked into the image). Set these to match the
# host user that owns WORKSPACE_PATH/CONFIG_BASE_PATH (run `id -u` / `id -g`
# on the host) if that user isn't UID/GID 1000 -- common on some NAS/Synology
# setups where the "normal" user has a different uid. Avoids having to
# `chown -R 1000:1000` your host directories; the container remaps its
# internal 'node' account to match instead. The container always starts as
# root internally to do this remap, then immediately drops to the resulting
# non-root user before running anything else -- it never stays root.
# PUID/PGID=0 is rejected (refuses to run as root).
# Example: PUID=1005
#          PGID=1005
PUID=1000
PGID=1000

# Path to your projects on the host (mounted at /workspace inside the container)
# Examples:
#   Standard Linux:  WORKSPACE_PATH=/home/user/projects
#   Unraid array:    WORKSPACE_PATH=/mnt/user/projects
#   Unraid cache:    WORKSPACE_PATH=/mnt/cache/projects
#   Synology:        WORKSPACE_PATH=/volume1/projects
#   Local test:      WORKSPACE_PATH=./workspaces
WORKSPACE_PATH=/mnt/user/projects

# Base directory where per-session config subdirectories are created.
# Each session gets its own isolated directory: CONFIG_BASE_PATH/REMOTE_SESSION_NAME
# Keep this directory secure — do not share or commit it.
# Examples:
#   Unraid (recommended): CONFIG_BASE_PATH=/mnt/user/appdata/claude-code-dock/configs
#   Standard Linux:       CONFIG_BASE_PATH=/home/user/claude-code-dock/configs
#   Local test:           CONFIG_BASE_PATH=./configs
CONFIG_BASE_PATH=/mnt/user/appdata/claude-code-dock/configs

# Unique identifier for this session (required).
# Used as: config subdirectory name, backup filename prefix, and default CONTAINER_NAME suffix.
# Two containers with the same REMOTE_SESSION_NAME cannot run simultaneously on the same host.
# Examples: homepage, finances, my-project, server1
REMOTE_SESSION_NAME=

# Docker container name (defaults to claude-code-dock-<REMOTE_SESSION_NAME> if not set).
# Docker enforces uniqueness — two containers with the same name cannot run simultaneously.
# Example: CONTAINER_NAME=claude-code-dock-homepage
CONTAINER_NAME=

# Shared configuration directory applied to all sessions at startup (optional).
# Files placed here are automatically applied across all sessions:
#   CLAUDE.md      → global instructions (coding style, commit rules, preferences)
#   commands/      → global slash commands / skills (*.md files)
# Instance-specific instructions go in: CONFIG_BASE_PATH/<session>/CLAUDE-local.md
# Examples:
#   Unraid: SHARED_CONFIG_PATH=/mnt/user/appdata/claude-code-dock/shared
#   Linux:  SHARED_CONFIG_PATH=/home/user/claude-code-dock/shared
SHARED_CONFIG_PATH=

# Container execution mode (determines PID 1 process)
#   interactive  — runs claude inside a tmux session (default, connect via attach.sh)
#   remote       — runs claude --remote-control inside a tmux session
#   shell        — runs bash (useful for debugging)
AUTO_START_MODE=interactive

# Auto-approve mode
#   true  — Claude runs without confirmation prompts (--dangerously-skip-permissions)
#   false — Claude asks for approval before each action (recommended default)
# Applies to interactive and remote modes. Only set to true once you trust the
# workspace this container points at — it removes Claude Code's own per-action
# confirmation, not just this project's.
CLAUDE_AUTO_APPROVE=false

# Claude Code version to install (optional — default: latest)
# Pin a specific version to avoid unexpected updates on rebuild.
# Examples: CLAUDE_CODE_VERSION=latest | CLAUDE_CODE_VERSION=2.3.1
CLAUDE_CODE_VERSION=latest

# Extra arguments appended to the final Claude command
# Examples: --model sonnet | --verbose | --debug
CLAUDE_EXTRA_ARGS=

# Container timezone
TZ=America/Sao_Paulo

# Git identity for commits made inside the container (optional)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

# GitHub Personal Access Token for push/pull authentication (optional).
# Required for Claude to push/pull from GitHub repositories inside the
# container. Leave empty if you only work with public repos or use SSH keys.
#
# HOST path to a file containing just the token (create it yourself, e.g.
# `echo -n ghp_xxx > /srv/claude-secrets/github_token && chmod 600 ...`).
# docker-compose.yml mounts this file automatically, read-only, into the
# container -- no extra steps needed. Leave empty to skip GitHub auth
# entirely (docker-compose.yml then mounts a harmless /dev/null instead).
#
# Create the token at: https://github.com/settings/tokens → "Classic token"
# → scope: repo.
#
# The token's value never sits in .env, in a docker-compose `environment:`
# line, or in the host shell's process environment -- only this path does.
# It's still readable via `docker exec <container> cat /run/secrets/github_token`
# by anyone with Docker daemon access on this host, same trust boundary as
# any other bind-mounted file. See docs/security.md for details.
# Example: GITHUB_TOKEN_FILE=/srv/claude-secrets/github_token
GITHUB_TOKEN_FILE=

# GitHub repository to clone into /workspace on first start (optional)
# HTTPS URL only — SSH is not supported inside the container.
# The workspace must be empty for auto-clone to run.
# Requires GITHUB_TOKEN_FILE if the repository is private.
# Example: GIT_REPO_URL=https://github.com/your-user/your-repo.git
GIT_REPO_URL=

# Number of backups to keep per session (oldest are removed automatically)
# Default: 10
BACKUP_RETENTION=10

# Passphrase used by `scripts/backup.sh --encrypt` for non-interactive GPG
# encryption (e.g. from cron). Optional — without it, --encrypt still works
# but gpg prompts interactively instead. Storing a passphrase here means .env
# itself becomes as sensitive as the backups it protects — keep it chmod 600.
BACKUP_ENCRYPT_PASSPHRASE=

# Optional webhook URL for scripts/watchdog.sh to notify when it restarts the
# container, fails to restart it, or skips it due to a fatal misconfiguration
# marker (see CLAUDE.md's scripts/watchdog.sh section). Works as-is with an
# ntfy.sh topic (https://ntfy.sh/your-topic-name) or any webhook that accepts
# a raw POST body. Silently a no-op if unset or if curl isn't installed on
# the host running the cron job (not the container).
# Example: WATCHDOG_NTFY_URL=https://ntfy.sh/my-claude-dock-alerts
WATCHDOG_NTFY_URL=
